{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#D9C8A9",
          "foreground": "#3C2C24",
          "powerline_symbol": "\ue0c4",
          "style": "powerline",
          "template": "\uf0e7",
          "type": "root"
        },
        {
          "background": "#3C2C24",
          "foreground": "#D9C8A9",
          "leading_diamond": " ",
          "style": "diamond",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#3C2C24",
          "foreground": "#A68A64",
          "powerline_symbol": "\ue0c4",
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "powerline",
          "template": "{{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "background": "#3C2C24",
          "foreground": "#8C7C5E",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "folder_separator_icon": "/",
            "style": "folder"
          },
          "style": "powerline",
          "template": "\ue5ff {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#3C2C24",
          "foreground": "#A68A64",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "#8C7C5E",
          "foreground": "#3C2C24",
          "powerline_symbol": "\ue0c4",
          "style": "powerline",
          "template": " \ue70c {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} ",
          "type": "dotnet"
        },
        {
          "background": "#A68A64",
          "foreground": "#3C2C24",
          "powerline_symbol": "\ue0c4",
          "properties": {
            "style": "austin",
            "threshold": 1
          },
          "style": "powerline",
          "template": " <#3C2C24>\ueba2</> {{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "background": "#3C2C24",
          "foreground": "#D9C8A9",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }} ",
          "type": "battery",
          "properties": {
            "discharging_icon": " ",
            "charging_icon": " ",
            "charged_icon": " "
          },
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}#8C7C5E{{end}}",
            "{{if eq \"Discharging\" .State.String}}#A68A64{{end}}",
            "{{if eq \"Full\" .State.String}}#D9C8A9{{end}}"
          ]
        },
        {
          "background": "#8C7C5E",
          "background_templates": [
            "{{ if gt .Code 0 }}#A68A64{{ end }}"
          ],
          "foreground": "#3C2C24",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": " \ueb05 ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#D9C8A9",
          "style": "plain",
          "template": "\u279c ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}(Admin) {{end}}{{.Folder}}",
  "version": 3
}

{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 8,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,

    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces", 
        "hyprland/window"
    ],
    
    "modules-center": [
        "clock"
    ],
    
    "modules-right": [
        "tray",
        "custom/updates",
        "network",
        "bluetooth",
        "pulseaudio",
        "pulseaudio#microphone",
        "battery",
        "custom/power-profiles",
        "custom/notification",
        "custom/power"
    ],

    // Launcher de aplicaГ§Гµes (como Activities)
    "custom/launcher": {
        "format": " у°Ј› ",
        "tooltip": false,
        "on-click": "wofi --show drun --allow-images --width 600 --height 400 --columns 3",
        "on-click-right": "wofi --show run --width 400 --height 200"
    },

    // Workspaces
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon}",
        "format-icons": {
            "1": "1",
            "2": "2", 
            "3": "3",
            "4": "4",
            "5": "п’©",
            "default": ""
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    // TГ­tulo da janela
    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "separate-outputs": true
    },

   // Rede - trocar para pop-up WiFi
    "network": {
        "format-wifi": "у°¤Ё {signalStrength}%",
        "format-ethernet": "у°€Ђ",
        "format-disconnected": "у°¤­",
        "tooltip-format": "{ifname} via {gwaddr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) у°¤Ё",
        "tooltip-format-ethernet": "{ifname} ",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "~/.config/hypr/scripts/network-manager.sh wifi",
        "on-click-right": "nm-connection-editor"
    },

    // Bluetooth - trocar blueman-manager pelo pop-up
    "bluetooth": {
        "format": "у°‚Ї",
        "format-disabled": "у°‚І",
        "format-connected": "у°‚± {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "~/.config/hypr/scripts/bluetooth-manager.sh"
    },

    // ГЃudio principal - trocar pavucontrol pelo pop-up
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "у°ќџ",
        "format-icons": {
            "headphone": "у°‹‹",
            "hands-free": "у°‹Ћ",
            "headset": "у°‹Ћ",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["у°•ї", "у°–Ђ", "у°•ѕ"]
        },
        "scroll-step": 5,
        "on-click": "~/.config/hypr/scripts/audio-selector.sh output",
        "on-click-right": "pavucontrol",
        "tooltip": true
    },

    // Microfone - trocar para pop-up de entrada
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "у°Ќ¬",
        "format-source-muted": "у°Ќ­",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-click-right": "~/.config/hypr/scripts/audio-selector.sh input",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%-",
        "tooltip": true
    },

    // Bateria
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "у°‚„ {capacity}%",
        "format-plugged": "у°‚„ {capacity}%", 
        "format-icons": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
        "on-click": "gnome-power-statistics",
        "tooltip": true
    },

    // Perfis de energia (como no Gnome)
    "custom/power-profiles": {
        "exec": "~/.config/waybar/scripts/power-profiles.sh",
        "interval": 10,
        "format": "{}",
        "tooltip": true,
        "on-click": "~/.config/waybar/scripts/power-profiles.sh toggle"
    },

    // AtualizaГ§Гµes do sistema
    "custom/updates": {
        "exec": "~/.config/waybar/scripts/updates.sh",
        "interval": 3600,
        "format": "{}",
        "tooltip": true,
        "on-click": "gnome-software --mode updates"
    },

    // RelГіgio com calendГЎrio
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%d/%m/%Y %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "on-click": "gnome-calendar",
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    // NotificaГ§Гµes
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "у°‚љ",
            "none": "у°‚њ",
            "dnd-notification": "у°‚›",
            "dnd-none": "у°‚њ",
            "inhibited-notification": "у°‚љ",
            "inhibited-none": "у°‚њ",
            "dnd-inhibited-notification": "у°‚›",
            "dnd-inhibited-none": "у°‚њ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    // Menu de energia
    "custom/power": {
        "format": " у°ђҐ ",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/power-menu.sh"
    },

    // System tray
    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": true
    }
}
